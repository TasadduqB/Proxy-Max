{
  "name": "proxy-max",
  "version": "2.0.0",
  "description": "Route Claude Code to any model — AWS Bedrock, Azure AI, NVIDIA NIM. Full tool calling, streaming, 100+ models. Zero-config AI gateway.",
  "main": "src/server.js",
  "keywords": [
    "claude-code",
    "proxy",
    "anthropic",
    "bedrock",
    "azure",
    "nvidia",
    "llm",
    "ai-gateway",
    "tool-calling",
    "openai",
    "gpt",
    "llama",
    "deepseek",
    "cursor",
    "windsurf"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TasadduqB/Proxy-Layer-For-Anthropic-Foundry-BedRock-Nvidia.git"
  },
  "author": "Tasadduq Burney",
  "homepage": "https://github.com/TasadduqB/Proxy-Layer-For-Anthropic-Foundry-BedRock-Nvidia#readme",
  "bugs": {
    "url": "https://github.com/TasadduqB/Proxy-Layer-For-Anthropic-Foundry-BedRock-Nvidia/issues"
  },
  "bin": {
    "proxy-max": "src/launch.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "launch": "node src/launch.js",
    "doctor": "node src/install.js"
  },
  "comments": {
    "sqlite": "Persistence uses Node's built-in node:sqlite (Node >=22.5) with an automatic JSON fallback on older runtimes — no native module to compile.",
    "undici": "Auto-installed on first use if not present; the proxy falls back gracefully if it can't be installed."
  },
  "dependencies": {
    "js-tiktoken": "^1.0.21",
    "toml": "^4.1.1",
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
